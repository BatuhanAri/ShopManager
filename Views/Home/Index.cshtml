@{
    ViewData["Title"] = "Dashboard";
}
@using ShopManager.Models

<div class="row g-3 mb-4">
    <div class="col-12">
        <h1 class="sm-page-title">
            <i class="bi bi-speedometer2 me-2 text-info"></i>Bugünkü Özet
            <small class="text-white-50 fs-6 ms-2">@DateTime.Now.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))</small>
        </h1>
    </div>

    <!-- Summary Cards -->
    <div class="col-6 col-md-3">
        <div class="sm-card sm-card-cash h-100">
            <div class="sm-card-icon"><i class="bi bi-cash-stack"></i></div>
            <div class="sm-card-label">Nakit</div>
            <div class="sm-card-value">@ViewBag.TodayCash.ToString("N2") ₺</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="sm-card sm-card-card h-100">
            <div class="sm-card-icon"><i class="bi bi-credit-card"></i></div>
            <div class="sm-card-label">Kart</div>
            <div class="sm-card-value">@ViewBag.TodayCard.ToString("N2") ₺</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="sm-card sm-card-ecom h-100">
            <div class="sm-card-icon"><i class="bi bi-globe2"></i></div>
            <div class="sm-card-label">E-Ticaret</div>
            <div class="sm-card-value">@ViewBag.TodayECommerce.ToString("N2") ₺</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="sm-card sm-card-total h-100">
            <div class="sm-card-icon"><i class="bi bi-graph-up-arrow"></i></div>
            <div class="sm-card-label">Toplam Ciro</div>
            <div class="sm-card-value">@ViewBag.TodayTotal.ToString("N2") ₺</div>
        </div>
    </div>
</div>

<!-- Critical Stock Warning -->
<div class="row g-3">
    <div class="col-12">
        <div class="sm-section-card">
            <div class="sm-section-header d-flex align-items-center justify-content-between flex-wrap gap-2">
                <h2 class="sm-section-title mb-0">
                    <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>Kritik Stok Uyarıları
                </h2>
                <a href="/Stock" class="btn sm-btn-outline btn-sm">
                    <i class="bi bi-box-seam me-1"></i>Stok Yönetimi
                </a>
            </div>

            @{
                var criticalStocks = ViewBag.CriticalStocks as List<Stock>;
            }

            @if (criticalStocks == null || !criticalStocks.Any())
            {
                <div class="sm-empty-state">
                    <i class="bi bi-check-circle-fill text-success fs-1 d-block mb-2"></i>
                    <p class="mb-0 text-white-50">Tüm ürünler yeterli stok seviyesinde 🎉</p>
                </div>
            }
            else
            {
                <div class="table-responsive mt-3">
                    <table class="table sm-table sm-table-critical">
                        <thead>
                            <tr>
                                <th><i class="bi bi-box-seam me-1"></i>Ürün</th>
                                <th class="text-end">Mevcut</th>
                                <th class="text-end">Kritik Limit</th>
                                <th class="text-center">Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in criticalStocks)
                            {
                                <tr class="sm-critical-row">
                                    <td class="fw-semibold">@s.ItemName</td>
                                    <td class="text-end text-danger fw-bold">@s.CurrentQuantity.ToString("G29") @s.Unit</td>
                                    <td class="text-end text-white-50">@s.CriticalLimit.ToString("G29") @s.Unit</td>
                                    <td class="text-center">
                                        @if (s.CurrentQuantity == 0)
                                        {
                                            <span class="badge sm-badge-empty"><i class="bi bi-x-circle-fill me-1"></i>TÜKENDİ</span>
                                        }
                                        else
                                        {
                                            <span class="badge sm-badge-critical"><i class="bi bi-exclamation-circle-fill me-1"></i>KRİTİK</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Quick links -->
    <div class="col-12 col-md-6">
        <a href="/DailyTurnover/Create" class="sm-quick-link d-flex align-items-center gap-3">
            <div class="sm-quick-icon bg-success bg-opacity-25"><i class="bi bi-plus-circle-fill text-success fs-3"></i></div>
            <div>
                <div class="fw-bold">Günü Kapat</div>
                <div class="text-white-50 small">Bugünün cirosunu kaydet</div>
            </div>
            <i class="bi bi-chevron-right ms-auto text-white-50"></i>
        </a>
    </div>
    <div class="col-12 col-md-6">
        <a href="/Stock" class="sm-quick-link d-flex align-items-center gap-3">
            <div class="sm-quick-icon bg-primary bg-opacity-25"><i class="bi bi-box-seam fs-3 text-primary"></i></div>
            <div>
                <div class="fw-bold">Stok Güncelle</div>
                <div class="text-white-50 small">Malzeme gir / çıkar</div>
            </div>
            <i class="bi bi-chevron-right ms-auto text-white-50"></i>
        </a>
    </div>
</div>
